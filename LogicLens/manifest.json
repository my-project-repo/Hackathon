{
  "manifest_version": 3,

  "name": "LogicLens",

  "version": "1.0.0",

  "description": "Realtime DSA Mentor",

  "permissions": [],

  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.hackerrank.com/*",
    "https://www.geeksforgeeks.org/*",
    "https://codeforces.com/*",
    "https://www.codechef.com/*",
    "https://atcoder.jp/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.leetcode.com/*",
        "https://*.hackerrank.com/*",
        "https://*.geeksforgeeks.org/*",
        "https://codeforces.com/*",
        "https://www.codechef.com/*",
        "https://*.atcoder.jp/*"
      ],

      "js": [
            "libs/babel.min.js",
            "engine/sanitizeCode.js",
            "parsers/javascriptParser.js",
            "parsers/javaParser.js",
            "parsers/pythonParser.js",

            "engine/traverseAst.js",
            "engine/generateReadableCode.js",
            "engine/symbolTable.js",
            "engine/patternClassifier.js",
            "engine/typeInference.js",


            "rules/offByOneRule.js",
            "rules/infiniteLoopRule.js",
            "rules/recursionRule.js",
            "rules/nullAccessRule.js",
            "rules/assignmentConditionRule.js",
            "rules/unreachableCodeRule.js",
            "rules/emptyLoopRule.js",
            "rules/apiMisuseRule.js",
            "rules/mutatingArrayRule.js",
            "rules/missingReturnRule.js",
            "rules/floatingPointEqualityRule.js",
            "rules/stackOverflowRule.js",
            "rules/duplicateConditionRule.js",
            "rules/missingEdgeCaseRule.js",
            "rules/slidingWindowShrinkRule.js",
            "rules/dpStateRule.js",
            "rules/binarySearchMidOverflowRule.js",
            "rules/moduloByZeroRule.js",
            "rules/missingHashMapExistenceRule.js",
            "rules/incorrectLoopUpdateRule.js",

            "ui/chat-panel.js",
        
            "content.js"
            ],

      "css": ["styles.css"],

      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "libs/babel.min.js",
        "ui/chat-panel.html",
        "ui/chat-panel.css",
        "ui/chat-panel.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}